{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(npx*)",
      "Bash(composer install*)",
      "Bash(composer update*)",
      "Bash(php artisan*)",
      "Bash(docker compose*)",
      "Bash(cp .env.example .env*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./storage/oauth-private.key)",
      "Read(./storage/oauth-public.key)",
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  }
}